<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#080d1d">
    <meta
      name="description"
      content="A new IPI experience is coming August 1, 2026 at 12:00 AM California time."
    >
    <meta property="og:title" content="IPI — A new experience is coming">
    <meta
      property="og:description"
      content="Follow the countdown to the new IPI website, launching August 1 at midnight in California."
    >
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://ipi.io/">
    <meta property="og:image" content="https://ipi.io/ipi-social.png?v=dark-card-20260715-2">
    <meta property="og:image:url" content="https://ipi.io/ipi-social.png?v=dark-card-20260715-2">
    <meta property="og:image:secure_url" content="https://ipi.io/ipi-social.png?v=dark-card-20260715-2">
    <meta property="og:image:type" content="image/png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Official IPI logo">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="IPI — A new experience is coming">
    <meta
      name="twitter:description"
      content="Follow the countdown to the new IPI website, launching August 1 at midnight in California."
    >
    <meta name="twitter:image" content="https://ipi.io/ipi-social.png?v=dark-card-20260715-2">
    <meta name="twitter:image:alt" content="Official IPI logo">
    <title>IPI — A new experience is coming</title>
    <link rel="image_src" href="https://ipi.io/ipi-social.png?v=dark-card-20260715-2">
    <link rel="icon" href="/ipi-logo.svg?v=official-x-20260715" type="image/svg+xml">
    <link rel="stylesheet" href="/landing.css?v=20260715-overflow1">
  </head>
  <body>
    <div class="ambient ambient-one" aria-hidden="true"></div>
    <div class="ambient ambient-two" aria-hidden="true"></div>
    <div class="grid-glow" aria-hidden="true"></div>

    <header class="site-header">
      <a class="brand" href="/" aria-label="IPI home">
        <span class="brand-mark" aria-hidden="true">
          <img src="/ipi-logo.svg?v=official-x-20260715" alt="">
        </span>
        <span class="brand-copy">
          <strong>IPI</strong>
          <small>Independent Protocol Infrastructure</small>
        </span>
      </a>

      <nav class="header-links" aria-label="IPI services">
        <a href="https://scan.ipi.io/">Scan</a>
        <a href="https://wallet.ipi.io/">Wallet</a>
        <a href="https://github.com/ipicoin">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-orbit" aria-hidden="true">
          <span class="orbit orbit-one"></span>
          <span class="orbit orbit-two"></span>
          <span class="orbit-core"></span>
        </div>

        <div class="hero-content">
          <div class="eyebrow">
            <span class="pulse-dot" aria-hidden="true"></span>
            The next chapter of IPI
          </div>

          <h1 id="hero-title">
            Something new is
            <span>taking shape.</span>
          </h1>

          <p class="hero-lead">
            We are bringing the IPI Terminal, product identity, wallet approval,
            and chain-backed ownership into one connected experience. The new IPI
            website will reveal what comes next.
          </p>

          <div class="launch-date">
            <span class="launch-label">Website reveal</span>
            <strong>August 1, 2026 · 12:00 AM PDT</strong>
            <small>California · America/Los_Angeles</small>
          </div>

          <div class="countdown-shell" aria-label="Countdown to the new IPI website">
            <div class="countdown" id="countdown">
              <div class="time-unit">
                <div class="digit-frame"><span id="days">00</span></div>
                <small>Days</small>
              </div>
              <div class="countdown-separator" aria-hidden="true">:</div>
              <div class="time-unit">
                <div class="digit-frame"><span id="hours">00</span></div>
                <small>Hours</small>
              </div>
              <div class="countdown-separator" aria-hidden="true">:</div>
              <div class="time-unit">
                <div class="digit-frame"><span id="minutes">00</span></div>
                <small>Minutes</small>
              </div>
              <div class="countdown-separator" aria-hidden="true">:</div>
              <div class="time-unit">
                <div class="digit-frame"><span id="seconds">00</span></div>
                <small>Seconds</small>
              </div>
            </div>

            <div class="countdown-progress" aria-hidden="true">
              <span id="countdown-progress-bar"></span>
            </div>

            <p class="countdown-status" id="countdown-status" aria-live="polite">
              Counting down to midnight in California
            </p>
            <noscript>
              <p class="countdown-status">Enable JavaScript to see the live countdown.</p>
            </noscript>
          </div>

          <div class="hero-actions">
            <a class="button button-primary" href="https://scan.ipi.io/">
              Explore the live testnet
              <span aria-hidden="true">↗</span>
            </a>
            <a class="button button-secondary" href="#building">See what we are building</a>
          </div>
        </div>
      </section>

      <section class="building" id="building" aria-labelledby="building-title">
        <div class="section-heading">
          <span class="eyebrow compact">Built as one system</span>
          <h2 id="building-title">From a physical product to digital ownership.</h2>
          <p>
            IPI is being developed as a complete product journey, with every layer
            designed to work together instead of existing as a disconnected demo.
          </p>
        </div>

        <div class="feature-grid">
          <article class="feature-card accent-red">
            <span class="feature-number">01</span>
            <div class="feature-icon" aria-hidden="true">▦</div>
            <h3>IPI Terminal</h3>
            <p>Product checkout, receipt history, and a clear in-store interaction flow.</p>
            <span class="feature-state">In active development</span>
          </article>

          <article class="feature-card accent-cyan">
            <span class="feature-number">02</span>
            <div class="feature-icon" aria-hidden="true">⌁</div>
            <h3>Product identity</h3>
            <p>NFC-based identification today, with secure authentication planned next.</p>
            <span class="feature-state">Physical testing underway</span>
          </article>

          <article class="feature-card accent-purple">
            <span class="feature-number">03</span>
            <div class="feature-icon" aria-hidden="true">◫</div>
            <h3>IPI Wallet</h3>
            <p>A human approval layer connecting a customer to an IPI checkout.</p>
            <span class="feature-state">Connection layer planned</span>
          </article>

          <article class="feature-card accent-green">
            <span class="feature-number">04</span>
            <div class="feature-icon" aria-hidden="true">◇</div>
            <h3>IPI Chain</h3>
            <p>The public testnet foundation for ownership, verification, and settlement.</p>
            <span class="feature-state"><i></i> Testnet live</span>
          </article>
        </div>
      </section>

      <section class="live-strip" aria-label="Live IPI testnet services">
        <div>
          <span class="live-dot" aria-hidden="true"></span>
          <span>
            <small>Available today</small>
            <strong>The IPI public testnet is live.</strong>
          </span>
        </div>
        <nav aria-label="Live testnet links">
          <a href="https://scan.ipi.io/">IPI Scan <span>↗</span></a>
          <a href="https://wallet.ipi.io/">Wallet gateway <span>↗</span></a>
          <a href="https://status-testnet.ipi.io/">Network status <span>↗</span></a>
        </nav>
      </section>
    </main>

    <footer>
      <span>IPI · Independent Protocol Infrastructure</span>
      <span>New website · August 1, 2026 · California</span>
    </footer>

    <script is:inline src="/landing.js?v=20260715" defer></script>
  </body>
</html>
